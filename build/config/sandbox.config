# Sandbox-safe BusyBox config fragment.
#
# Applied over `make allnoconfig` by scripts/apply-config.sh. Each non-blank,
# non-comment line is one Kconfig setting (CONFIG_X=y, CONFIG_X=n, or
# CONFIG_X="literal"). Every line must match an existing symbol in BusyBox's
# Kconfig — apply-config.sh assumes upstream symbol renames will fail loudly
# via `make oldconfig`'s "trying to assign nonexistent symbol" warning.
#
# Scope: text/file/archive utilities that work without fork/exec, sockets,
# /proc, mount, ptrace, tty ioctls or setuid.

# ---------------------------------------------------------------------------
# Build-level / global features
# ---------------------------------------------------------------------------
# CONFIG_BUSYBOX gates the "busybox" multi-call dispatch itself. Without it,
# `busybox <applet> ...` and `busybox --help` both report "applet not found"
# because the if (is_prefixed_with(name, "busybox")) branch in
# libbb/appletlib.c:run_applet_and_exit is compiled out.
CONFIG_BUSYBOX=y
CONFIG_DESKTOP=y
CONFIG_LFS=y
CONFIG_LONG_OPTS=y
CONFIG_INCLUDE_SUSv2=y
CONFIG_SHOW_USAGE=y
CONFIG_FEATURE_VERBOSE_USAGE=y
CONFIG_FEATURE_COMPRESS_USAGE=n
CONFIG_FEATURE_BUFFERS_USE_MALLOC=y
CONFIG_FEATURE_BUFFERS_GO_ON_STACK=n
CONFIG_FEATURE_BUFFERS_GO_IN_BSS=n
CONFIG_FEATURE_VERBOSE=y
CONFIG_FEATURE_COPYBUF_KB=4

# No setuid, no installer, no shared libbusybox.
CONFIG_FEATURE_SUID=n
CONFIG_FEATURE_SUID_CONFIG=n
CONFIG_FEATURE_SUID_CONFIG_QUIET=n
CONFIG_FEATURE_PREFER_APPLETS=n
CONFIG_FEATURE_SH_STANDALONE=n
CONFIG_FEATURE_SH_NOFORK=n
CONFIG_FEATURE_INSTALLER=n
CONFIG_INSTALL_NO_USR=y
CONFIG_SELINUX=n
CONFIG_FEATURE_SYSLOG=n
CONFIG_FEATURE_DEVPTS=n
CONFIG_FEATURE_UTMP=n
CONFIG_FEATURE_WTMP=n
CONFIG_FEATURE_PIDFILE=n
CONFIG_PID_FILE_PATH=""

# No networking — WASM has no sockets.
CONFIG_FEATURE_IPV6=n
CONFIG_FEATURE_PREFER_IPV4_ADDRESS=n
CONFIG_VERBOSE_RESOLUTION_ERRORS=n
CONFIG_FEATURE_ETC_NETWORKS=n
CONFIG_FEATURE_ETC_SERVICES=n
CONFIG_FEATURE_USE_SENDFILE=n

# ---------------------------------------------------------------------------
# Applets (sandbox-safe)
# ---------------------------------------------------------------------------

